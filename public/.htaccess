# Enable mod_rewrite for public folder
# VPS Path: /home/silverwebbuzz_in/public_html/drfeelgoods.in/app/public/
# URL: https://app.drfeelgoods.in/

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Set the base directory to /app/ (matches VPS deployment)
    RewriteBase /app/

    # Don't rewrite actual files or directories
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Rewrite everything to index.php
    RewriteRule ^(.*)$ index.php?path=$1 [QSA,L]
</IfModule>

# Disable directory browsing
Options -Indexes

# Allow access to public folder
<FilesMatch "\.(php|html|css|js|jpg|jpeg|png|gif|ico)$">
    Allow from all
</FilesMatch>
