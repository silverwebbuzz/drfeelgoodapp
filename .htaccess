# Dr. Feelgood - Root .htaccess
#
# VPS Path: /home/silverwebbuzz_in/public_html/drfeelgoods.in/app/
# URL: https://app.drfeelgoods.in/
# Entry Point: index.php (at root)

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Exclude real files and directories
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Exclude debug.php (allow direct access for testing)
    RewriteCond %{REQUEST_FILENAME} !debug.php

    # Rewrite all requests to index.php, preserving query string
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Disable directory browsing
Options -Indexes

# Disable directory indexing
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Set proper MIME types for common files
<IfModule mod_mime.c>
    AddType text/html .html
    AddType text/css .css
    AddType application/javascript .js
    AddType application/json .json
</IfModule>

# Prevent access to sensitive files
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Prevent access to config files
<FilesMatch "\.(env|sql|sqlite|db)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Allow access to public folder directly
<IfModule mod_rewrite.c>
    RewriteRule ^public/ - [L]
</IfModule>
